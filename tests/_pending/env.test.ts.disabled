/**
 * Tests unitarios — Validación de variables de entorno
 */
import { describe, it, expect } from 'vitest'
import { validatePublicEnv, validateServerEnv, validateAllEnv } from '@/lib/env'

const VALID_PUBLIC: Record<string, string> = {
  NEXT_PUBLIC_SITE_URL: 'https://kultura.app',
  NEXT_PUBLIC_SUPABASE_URL: 'https://abc.supabase.co',
  NEXT_PUBLIC_SUPABASE_ANON_KEY: 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.test',
}

const VALID_SERVER: Record<string, string> = {
  SUPABASE_SERVICE_ROLE_KEY: 'service_role_test_key',
  TMDB_API_KEY: 'tmdb_test_key_abc123',
  RAWG_API_KEY: 'rawg_test_key_abc123',
}

describe('validatePublicEnv', () => {
  it('pasa con todas las variables válidas', () => {
    expect(() => validatePublicEnv(VALID_PUBLIC)).not.toThrow()
  })

  it('retorna el objeto con los valores', () => {
    const env = validatePublicEnv(VALID_PUBLIC)
    expect(env.NEXT_PUBLIC_SITE_URL).toBe('https://kultura.app')
    expect(env.NEXT_PUBLIC_SUPABASE_URL).toBe('https://abc.supabase.co')
  })

  it('lanza error si NEXT_PUBLIC_SITE_URL falta', () => {
    const { NEXT_PUBLIC_SITE_URL: _, ...rest } = VALID_PUBLIC
    expect(() => validatePublicEnv(rest)).toThrow('NEXT_PUBLIC_SITE_URL')
  })

  it('lanza error si NEXT_PUBLIC_SUPABASE_URL falta', () => {
    const { NEXT_PUBLIC_SUPABASE_URL: _, ...rest } = VALID_PUBLIC
    expect(() => validatePublicEnv(rest)).toThrow('NEXT_PUBLIC_SUPABASE_URL')
  })

  it('lanza error si NEXT_PUBLIC_SUPABASE_ANON_KEY falta', () => {
    const { NEXT_PUBLIC_SUPABASE_ANON_KEY: _, ...rest } = VALID_PUBLIC
    expect(() => validatePublicEnv(rest)).toThrow('NEXT_PUBLIC_SUPABASE_ANON_KEY')
  })

  it('lanza error si NEXT_PUBLIC_SUPABASE_URL no es una URL válida', () => {
    expect(() =>
      validatePublicEnv({ ...VALID_PUBLIC, NEXT_PUBLIC_SUPABASE_URL: 'not-a-url' })
    ).toThrow('NEXT_PUBLIC_SUPABASE_URL')
  })

  it('el mensaje de error incluye el prefijo [KULTURA]', () => {
    try {
      validatePublicEnv({})
    } catch (e) {
      expect((e as Error).message).toContain('[KULTURA]')
    }
  })

  it('variables vacías se rechazan', () => {
    expect(() =>
      validatePublicEnv({ ...VALID_PUBLIC, NEXT_PUBLIC_SITE_URL: '' })
    ).toThrow()
  })
})

describe('validateServerEnv', () => {
  it('pasa con todas las variables de servidor presentes', () => {
    expect(() => validateServerEnv(VALID_SERVER)).not.toThrow()
  })

  it('lanza error si SUPABASE_SERVICE_ROLE_KEY falta', () => {
    const { SUPABASE_SERVICE_ROLE_KEY: _, ...rest } = VALID_SERVER
    expect(() => validateServerEnv(rest)).toThrow('SUPABASE_SERVICE_ROLE_KEY')
  })

  it('lanza error si TMDB_API_KEY falta', () => {
    const { TMDB_API_KEY: _, ...rest } = VALID_SERVER
    expect(() => validateServerEnv(rest)).toThrow('TMDB_API_KEY')
  })

  it('lanza error si RAWG_API_KEY falta', () => {
    const { RAWG_API_KEY: _, ...rest } = VALID_SERVER
    expect(() => validateServerEnv(rest)).toThrow('RAWG_API_KEY')
  })

  it('GOOGLE_BOOKS_KEY es opcional', () => {
    expect(() => validateServerEnv(VALID_SERVER)).not.toThrow()
  })

  it('lanza error si SUPABASE_SERVICE_ROLE_KEY está vacía', () => {
    expect(() =>
      validateServerEnv({ ...VALID_SERVER, SUPABASE_SERVICE_ROLE_KEY: '' })
    ).toThrow()
  })
})

describe('validateAllEnv', () => {
  it('pasa con todas las variables presentes', () => {
    expect(() =>
      validateAllEnv({ ...VALID_PUBLIC, ...VALID_SERVER })
    ).not.toThrow()
  })

  it('lanza error si falta alguna variable pública', () => {
    const { NEXT_PUBLIC_SITE_URL: _, ...rest } = VALID_PUBLIC
    expect(() =>
      validateAllEnv({ ...rest, ...VALID_SERVER })
    ).toThrow()
  })

  it('lanza error si falta una variable de servidor', () => {
    const { TMDB_API_KEY: _, ...rest } = VALID_SERVER
    expect(() => validateAllEnv({ ...VALID_PUBLIC, ...rest })).toThrow()
  })
})
