# TMDB — Películas y Series
# https://www.themoviedb.org/settings/api
NEXT_PUBLIC_TMDB_API_KEY=your_tmdb_key_here

# RAWG — Videojuegos
# https://rawg.io/apidocs
NEXT_PUBLIC_RAWG_KEY=your_rawg_key_here

# Google Books — Libros
# https://console.cloud.google.com/
NEXT_PUBLIC_GOOGLE_BOOKS_KEY=your_google_books_key_here

# ComicVine — SOLO SERVER-SIDE (CORS bloqueado en cliente)
# https://comicvine.gamespot.com/api/
COMICVINE_KEY=your_comicvine_key_here

# Anthropic Claude API — SOLO SERVER-SIDE
# https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# Supabase (producción)
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Supabase (proyecto separado SOLO para tests)
SUPABASE_TEST_URL=https://your-test-project.supabase.co
SUPABASE_TEST_ANON_KEY=your_test_anon_key_here
