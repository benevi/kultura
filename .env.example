# =============================================================================
# KULTURA — plantilla de variables de entorno
# Copia a .env.local y rellena. Sin valores reales aquí (este archivo SÍ va a git).
# Validación: src/lib/env.ts (Zod). Fail-fast en arranque vía instrumentation.ts.
# =============================================================================

# -----------------------------------------------------------------------------
# 1. REQUERIDAS (esquema Zod — el server no arranca sin ellas)
# -----------------------------------------------------------------------------

# URL del proyecto Supabase (pública, se inlinea en el bundle cliente)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Anon key de Supabase (pública, RLS protege los datos)
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase-anon-key>

# Service role key de Supabase — server-only, bypassa RLS. NUNCA con prefijo NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>

# API key de TMDB (películas + series) — server-only
TMDB_API_KEY=<tmdb-api-key>

# API key de RAWG (videojuegos) — server-only
RAWG_API_KEY=<rawg-api-key>

# -----------------------------------------------------------------------------
# 2. OPCIONALES (la app funciona sin ellas; string vacío = ausente)
# -----------------------------------------------------------------------------

# Base URL pública del sitio (SEO / og:url). Opcional.
NEXT_PUBLIC_SITE_URL=https://<dominio-produccion>

# API key de Anthropic Claude (recomendaciones IA, claude-haiku-4-5) — server-only.
# Debe empezar por "sk-ant-". Opcional: sin ella, las recomendaciones IA no funcionan.
ANTHROPIC_API_KEY=sk-ant-<anthropic-api-key>

# API key de ComicVine (cómics) — server-only. Opcional: sin uso en código actual (E6).
COMICVINE_KEY=<comicvine-api-key>

# -----------------------------------------------------------------------------
# 3. SOLO TESTS (no necesarias para desarrollo normal; viven en scripts y tests,
#    no pasan por el esquema Zod y no rompen el build si faltan)
# -----------------------------------------------------------------------------

# Proyecto Supabase separado para tests de integración (kultura-test)
SUPABASE_TEST_URL=https://<test-project-ref>.supabase.co
SUPABASE_TEST_ANON_KEY=<test-anon-key>
# service_role del proyecto de test — solo migraciones/seed, nunca en código de app
SUPABASE_TEST_SERVICE_ROLE_KEY=<test-service-role-key>

# Usuarios seedeados para specs E2E (Playwright)
TEST_USER_EMAIL=<email-usuario-a>
TEST_USER_PASSWORD=<password-compartida-a-y-b>
TEST_USER_B_EMAIL=<email-usuario-b>
# UUID del grupo seedeado (rellenar tras correr el seed B3.5e-2)
TEST_GROUP_ID=<uuid-grupo-seed>

# Nombres legacy pre-A4, solo usados por tests/contract/*.contract.test.ts.
# Deuda (E97): unificar con TMDB_API_KEY / RAWG_API_KEY.
NEXT_PUBLIC_TMDB_API_KEY=<tmdb-api-key>
NEXT_PUBLIC_RAWG_KEY=<rawg-api-key>
